{
  "name": "iwillnotpayforleetcodepremium",
  "version": "0.1.0",
  "description": "AI-assisted, no-autocomplete LeetCode-style practice workflow.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prepare": "husky || true",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "lint": "bun run format:check",
    "typecheck": "tsc --noEmit",
    "fix": "bun run format && bun run lint && bun run typecheck",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "typescript": "^5"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,cts,mts,cjs,mjs,json,md,mdx,css,scss,html}": "prettier --write --ignore-unknown"
  }
}
